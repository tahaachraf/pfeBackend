# ============================================================
# CONFIGURATION MONGODB ATLAS
# ============================================================
# Remplacez par votre URI de connexion MongoDB Atlas
# Format : mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://VOTRE_USER:VOTRE_PASSWORD@cluster0.xxxxx.mongodb.net/ecommerce?retryWrites=true&w=majority

# ============================================================
# CONFIGURATION DU SERVEUR
# ============================================================
PORT=3500
BASE_URL=http://localhost:3500

# ============================================================
# CONFIGURATION EMAIL GMAIL (SMTP)
# ============================================================
# ÉTAPES pour Gmail :
#   1. Allez sur : https://myaccount.google.com/security
#   2. Activez "Validation en deux étapes"
#   3. Allez sur : https://myaccount.google.com/apppasswords
#   4. Créez un "Mot de passe d'application" pour "Autre (nom personnalisé)"
#   5. Copiez le mot de passe généré dans EMAIL_PASSWORD ci-dessous
EMAIL=votre.email@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM_NAME=TunisieShopping

# ============================================================
# JWT SECRET (pour l'authentification par token)
# ============================================================
JWT_SECRET=changez-cette-valeur-secrete-longue-et-aleatoire-123456
